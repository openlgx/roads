# Copy to backend/.env.local (gitignored) for local Python workers and scripts.
# Never commit real secrets. Never embed these in the Android app.

# Neon (hosted alpha metadata + jobs)
DATABASE_URL=postgresql://user:pass@ep-xxxxx.region.aws.neon.tech/neondb?sslmode=require
# Optional: serverless-friendly pooler URL for Edge Functions
DATABASE_URL_POOLED=

# Supabase (Storage + Edge function hosting)
SUPABASE_PROJECT_URL=https://xxxxxxxx.supabase.co
SUPABASE_PROJECT_REF=xxxxxxxx
SUPABASE_SECRET_KEY=your-service-role-key
SUPABASE_ACCESS_TOKEN=

# Storage buckets (private)
SUPABASE_RAW_BUCKET=roads-alpha-raw
SUPABASE_PUBLISHED_BUCKET=roads-alpha-published

# Publisher / processing version labels
PUBLISHER_VERSION=0.1.0-alpha

# Processing worker
PROCESSING_MAX_JOBS=5
