# Copy to backend/.env.local (gitignored) for local Python workers and scripts.
# Never commit real secrets. Never embed these in the Android app.

# Neon (hosted alpha metadata + jobs)
DATABASE_URL=postgresql://user:pass@ep-xxxxx.region.aws.neon.tech/neondb?sslmode=require
# Optional: serverless-friendly pooler URL for Edge Functions
DATABASE_URL_POOLED=

# Supabase (Storage + Edge function hosting)
SUPABASE_PROJECT_URL=https://xxxxxxxx.supabase.co
SUPABASE_PROJECT_REF=xxxxxxxx
SUPABASE_SECRET_KEY=your-service-role-key
SUPABASE_ACCESS_TOKEN=

# Supabase Edge Functions (Dashboard → Edge Functions → Secrets for each deployed function).
# Same names as below; Neon URL is required for all functions using _shared/neon.ts:
#   DATABASE_URL  OR  DATABASE_URL_POOLED  (prefer pooled for serverless)
#   SUPABASE_PROJECT_URL, SUPABASE_SECRET_KEY
#   SUPABASE_RAW_BUCKET, SUPABASE_PUBLISHED_BUCKET (council layer functions)

# Storage buckets (private)
SUPABASE_RAW_BUCKET=roads-alpha-raw
SUPABASE_PUBLISHED_BUCKET=roads-alpha-published

# Optional: align with Supabase client / smoke tools (same as SUPABASE_PROJECT_URL + /functions/v1)
# UPLOAD_BASE_URL=https://xxxxxxxx.supabase.co/functions/v1
# DEVICE_UPLOAD plaintext (Neon api_keys), not SUPABASE_SECRET_KEY — see scripts/issue_device_upload_key.py
# UPLOAD_API_KEY=
# PILOT_DEVICE_UPLOAD_KEY=   # optional duplicate for pilot_smoke_e2e.py (or rely on UPLOAD_API_KEY)

# Reserved for future key-signing schemes (not used by current Edge handlers; keep out of docs/examples)
# API_KEY_SIGNING_SECRET=

# Publisher / processing version labels
PUBLISHER_VERSION=0.1.0-alpha

# Processing worker
PROCESSING_MAX_JOBS=5
