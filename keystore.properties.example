# Local release signing (copy to keystore.properties — DO NOT COMMIT keystore.properties)
#
# Paths are relative to the repository root unless you use an absolute path.
# Environment variables ROADS_* override these values when set (see docs/android-release-signing.md).

storeFile=path/to/your-release-key.jks
storePassword=your-store-password
keyAlias=your-key-alias
keyPassword=your-key-password
